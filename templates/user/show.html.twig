{% extends 'base.html.twig' %}

{% block title %}{{ user.firstname }} {{ user.lastname }}{% endblock %}
{% block page_title %}{{ user.firstname }} {{ user.lastname }}{% endblock %}

{% block breadcrumb %}
<nav class="flex items-center gap-1.5 text-xs text-[#6e6e73] mt-0.5">
    <a href="{{ path('app_user_index') }}" class="hover:text-[#0071e3] transition-colors">Membres</a>
    <span>›</span>
    <span class="text-[#1d1d1f]">{{ user.firstname }} {{ user.lastname }}</span>
</nav>
{% endblock %}

{% block header_actions %}
<a href="{{ path('app_user_index') }}"
   class="flex items-center gap-1.5 px-3.5 py-1.5 text-sm font-medium text-[#6e6e73] bg-white border border-[#d2d2d7] rounded-xl hover:bg-[#f5f5f7] transition-colors">
    ← Retour
</a>
{% endblock %}

{% block body %}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    {# ── Profile card ── #}
    <div class="bg-white rounded-2xl border border-[#d2d2d7] p-6">
        <div class="text-center mb-5">
            <div class="w-20 h-20 rounded-full bg-gradient-to-br from-[#0071e3] to-[#00c7be] flex items-center justify-center text-white text-2xl font-semibold mx-auto mb-3">
                {{ user.firstname|first|upper }}{{ user.lastname|first|upper }}
            </div>
            <h2 class="text-lg font-semibold text-[#1d1d1f]">{{ user.firstname }} {{ user.lastname }}</h2>
            <p class="text-sm text-[#6e6e73]">{{ user.email }}</p>
            <div class="mt-2 flex items-center justify-center gap-2">
                <span class="px-2.5 py-1 rounded-full text-xs font-medium
                    {% if user.role == 'ADMIN' %}bg-red-50 text-red-600
                    {% elseif user.role == 'COACH' %}bg-blue-50 text-blue-600
                    {% elseif user.role == 'PLAYER' %}bg-green-50 text-green-600
                    {% else %}bg-amber-50 text-amber-600{% endif %}">
                    {{ user.role }}
                </span>
                <span class="inline-flex items-center gap-1 text-xs font-medium
                    {% if user.status == 'ACTIVE' %}text-green-600{% elseif user.status == 'SUSPENDED' %}text-red-600{% else %}text-[#6e6e73]{% endif %}">
                    <span class="w-1.5 h-1.5 rounded-full
                        {% if user.status == 'ACTIVE' %}bg-green-500{% elseif user.status == 'SUSPENDED' %}bg-red-500{% else %}bg-[#d2d2d7]{% endif %}">
                    </span>
                    {{ user.status }}
                </span>
            </div>
        </div>

        <div class="border-t border-[#f5f5f7] pt-5 space-y-3">
            {% if user.phone %}
            <div class="flex items-center gap-3 text-sm">
                <svg class="w-4 h-4 text-[#6e6e73] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                <span class="text-[#1d1d1f]">{{ user.phone }}</span>
            </div>
            {% endif %}

            {% if user.team %}
            <div class="flex items-center gap-3 text-sm">
                <svg class="w-4 h-4 text-[#6e6e73] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"/>
                </svg>
                <span class="text-[#1d1d1f]">{{ user.team.name }}</span>
            </div>
            {% endif %}

            {% if user.club %}
            <div class="flex items-center gap-3 text-sm">
                <svg class="w-4 h-4 text-[#6e6e73] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                </svg>
                <span class="text-[#1d1d1f]">{{ user.club.name }}</span>
            </div>
            {% endif %}
        </div>
    </div>

    {# ── Info panels ── #}
    <div class="lg:col-span-2 space-y-5">

        {# Informations personnelles #}
        <div class="bg-white rounded-2xl border border-[#d2d2d7] overflow-hidden">
            <div class="px-6 py-4 border-b border-[#f5f5f7]">
                <h3 class="text-sm font-semibold text-[#1d1d1f]">Informations personnelles</h3>
            </div>
            <div class="px-6 py-4 grid grid-cols-2 gap-x-8 gap-y-4">
                <div>
                    <p class="text-xs text-[#6e6e73] mb-0.5">Prénom</p>
                    <p class="text-sm font-medium text-[#1d1d1f]">{{ user.firstname }}</p>
                </div>
                <div>
                    <p class="text-xs text-[#6e6e73] mb-0.5">Nom</p>
                    <p class="text-sm font-medium text-[#1d1d1f]">{{ user.lastname }}</p>
                </div>
                <div>
                    <p class="text-xs text-[#6e6e73] mb-0.5">Email</p>
                    <p class="text-sm font-medium text-[#1d1d1f]">{{ user.email }}</p>
                </div>
                <div>
                    <p class="text-xs text-[#6e6e73] mb-0.5">Téléphone</p>
                    <p class="text-sm font-medium text-[#1d1d1f]">{{ user.phone ?? '—' }}</p>
                </div>
                <div>
                    <p class="text-xs text-[#6e6e73] mb-0.5">Date de naissance</p>
                    <p class="text-sm font-medium text-[#1d1d1f]">
                        {% if user.birhdate %}{{ user.birhdate|date('d/m/Y') }}{% else %}—{% endif %}
                    </p>
                </div>
                <div>
                    <p class="text-xs text-[#6e6e73] mb-0.5">Membre depuis</p>
                    <p class="text-sm font-medium text-[#1d1d1f]">
                        {% if user.createdAt %}{{ user.createdAt|date('d/m/Y') }}{% else %}—{% endif %}
                    </p>
                </div>
            </div>
        </div>

        {# Contact d'urgence #}
        {% if user.emergencyContactName or user.emergencyContactPhone %}
        <div class="bg-white rounded-2xl border border-[#d2d2d7] overflow-hidden">
            <div class="px-6 py-4 border-b border-[#f5f5f7]">
                <h3 class="text-sm font-semibold text-[#1d1d1f]">Contact d'urgence</h3>
            </div>
            <div class="px-6 py-4 grid grid-cols-2 gap-x-8 gap-y-4">
                <div>
                    <p class="text-xs text-[#6e6e73] mb-0.5">Nom</p>
                    <p class="text-sm font-medium text-[#1d1d1f]">{{ user.emergencyContactName ?? '—' }}</p>
                </div>
                <div>
                    <p class="text-xs text-[#6e6e73] mb-0.5">Téléphone</p>
                    <p class="text-sm font-medium text-[#1d1d1f]">{{ user.emergencyContactPhone ?? '—' }}</p>
                </div>
            </div>
        </div>
        {% endif %}

        {# Parent (si joueur mineur) #}
        {% if user.parent %}
        <div class="bg-white rounded-2xl border border-[#d2d2d7] overflow-hidden">
            <div class="px-6 py-4 border-b border-[#f5f5f7]">
                <h3 class="text-sm font-semibold text-[#1d1d1f]">Responsable légal</h3>
            </div>
            <div class="px-6 py-4 flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-white text-xs font-semibold flex-shrink-0">
                    {{ user.parent.firstname|first|upper }}{{ user.parent.lastname|first|upper }}
                </div>
                <div>
                    <p class="text-sm font-medium text-[#1d1d1f]">{{ user.parent.firstname }} {{ user.parent.lastname }}</p>
                    <p class="text-xs text-[#6e6e73]">{{ user.parent.email }}</p>
                </div>
                <a href="{{ path('app_user_show', {id: user.parent.id}) }}"
                   class="ml-auto text-xs text-[#0071e3] font-medium hover:underline">
                    Voir le profil →
                </a>
            </div>
        </div>
        {% endif %}

    </div>
</div>

{% endblock %}
