{% extends 'base.html.twig' %}

{% block title %}{{ event.title }}{% endblock %}
{% block page_title %}{{ event.title }}{% endblock %}

{% block breadcrumb %}
<nav class="flex items-center gap-1.5 text-xs text-[#6e6e73] mt-0.5">
    <a href="{{ path('app_event_index') }}" class="hover:text-[#0071e3] transition-colors">Événements</a>
    <span>›</span>
    <span class="text-[#1d1d1f]">{{ event.title }}</span>
</nav>
{% endblock %}

{% block header_actions %}
<a href="{{ path('app_event_index') }}"
   class="flex items-center gap-1.5 px-3.5 py-1.5 text-sm font-medium text-[#6e6e73] bg-white border border-[#d2d2d7] rounded-xl hover:bg-[#f5f5f7] transition-colors">
    ← Retour
</a>
{% endblock %}

{% block body %}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    {# Info card #}
    <div class="bg-white rounded-2xl border border-[#d2d2d7] p-6">
        <div class="w-14 h-14 rounded-2xl bg-purple-50 flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-purple-600" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
        </div>
        <h2 class="text-lg font-semibold text-[#1d1d1f] mb-1">{{ event.title }}</h2>
        {% if event.eventType %}
        <p class="text-xs text-[#6e6e73] mb-4">{{ event.eventType.name }}</p>
        {% endif %}

        <div class="border-t border-[#f5f5f7] pt-4 space-y-3">
            <div>
                <p class="text-xs text-[#6e6e73] mb-0.5">Équipe</p>
                <p class="text-sm font-medium text-[#1d1d1f]">{{ event.team ? event.team.name : '—' }}</p>
            </div>
            <div>
                <p class="text-xs text-[#6e6e73] mb-0.5">Lieu</p>
                <p class="text-sm font-medium text-[#1d1d1f]">{{ event.location ?? '—' }}</p>
            </div>
            <div>
                <p class="text-xs text-[#6e6e73] mb-0.5">Horaire</p>
                <p class="text-sm font-medium text-[#1d1d1f]">
                    {% if event.startTime and event.endTime %}
                        {{ event.startTime|date('H:i') }} → {{ event.endTime|date('H:i') }}
                    {% else %}—{% endif %}
                </p>
            </div>
            <div>
                <p class="text-xs text-[#6e6e73] mb-0.5">Saison</p>
                <p class="text-sm font-medium text-[#1d1d1f]">
                    {% if event.seasonStartDate and event.seasonEndDate %}
                        {{ event.seasonStartDate|date('d/m/Y') }} → {{ event.seasonEndDate|date('d/m/Y') }}
                    {% else %}—{% endif %}
                </p>
            </div>
        </div>
    </div>

    {# Details #}
    <div class="lg:col-span-2 space-y-5">

        {% if event.description %}
        <div class="bg-white rounded-2xl border border-[#d2d2d7] p-6">
            <h3 class="text-sm font-semibold text-[#1d1d1f] mb-3">Description</h3>
            <p class="text-sm text-[#6e6e73] leading-relaxed">{{ event.description }}</p>
        </div>
        {% endif %}

        {% if event.recurrenceRule %}
        <div class="bg-white rounded-2xl border border-[#d2d2d7] p-6">
            <h3 class="text-sm font-semibold text-[#1d1d1f] mb-3">Récurrence</h3>
            <code class="text-xs bg-[#f5f5f7] text-[#1d1d1f] px-3 py-1.5 rounded-lg font-mono block">{{ event.recurrenceRule }}</code>
        </div>
        {% endif %}

        <div class="bg-white rounded-2xl border border-[#d2d2d7] overflow-hidden">
            <div class="px-6 py-4 border-b border-[#f5f5f7]">
                <h3 class="text-sm font-semibold text-[#1d1d1f]">Séances (occurrences)</h3>
            </div>
            <div class="py-16 text-center">
                <p class="text-sm text-[#6e6e73]">Les séances seront générées automatiquement depuis la règle de récurrence</p>
            </div>
        </div>

    </div>
</div>

{% endblock %}
