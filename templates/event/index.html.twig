{% extends 'base.html.twig' %}

{% block title %}Événements{% endblock %}
{% block page_title %}Événements{% endblock %}

{% block breadcrumb %}
<p class="text-xs text-[#6e6e73] mt-0.5">{{ events|length }} événement{{ events|length != 1 ? 's' : '' }}</p>
{% endblock %}

{% block body %}

{% if events is empty %}
<div class="bg-white rounded-2xl border border-[#d2d2d7] py-20 text-center">
    <svg class="w-12 h-12 text-[#d2d2d7] mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
    </svg>
    <p class="text-sm font-medium text-[#1d1d1f] mb-1">Aucun événement</p>
    <p class="text-xs text-[#6e6e73]">Créez votre premier événement récurrent</p>
</div>

{% else %}
<div class="bg-white rounded-2xl border border-[#d2d2d7] overflow-hidden">
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-[#f5f5f7]">
                <th class="px-6 py-3 text-left text-xs font-semibold text-[#6e6e73] uppercase tracking-wider">Événement</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-[#6e6e73] uppercase tracking-wider">Équipe</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-[#6e6e73] uppercase tracking-wider">Lieu</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-[#6e6e73] uppercase tracking-wider">Saison</th>
                <th class="px-6 py-3"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-[#f5f5f7]">
            {% for event in events %}
            <tr class="hover:bg-[#f5f5f7] transition-colors group">
                <td class="px-6 py-3.5">
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-xl bg-purple-50 flex items-center justify-center flex-shrink-0">
                            <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="font-medium text-[#1d1d1f]">{{ event.title }}</p>
                            {% if event.eventType %}
                            <p class="text-xs text-[#6e6e73]">{{ event.eventType.name }}</p>
                            {% endif %}
                        </div>
                    </div>
                </td>
                <td class="px-6 py-3.5 text-[#6e6e73]">
                    {{ event.team ? event.team.name : '—' }}
                </td>
                <td class="px-6 py-3.5 text-[#6e6e73]">
                    {{ event.location ?? '—' }}
                </td>
                <td class="px-6 py-3.5 text-[#6e6e73] text-xs">
                    {% if event.seasonStartDate and event.seasonEndDate %}
                        {{ event.seasonStartDate|date('d/m/Y') }} → {{ event.seasonEndDate|date('d/m/Y') }}
                    {% else %}
                        —
                    {% endif %}
                </td>
                <td class="px-6 py-3.5 text-right">
                    <a href="{{ path('app_event_show', {id: event.id}) }}"
                       class="opacity-0 group-hover:opacity-100 transition-opacity text-xs text-[#0071e3] font-medium hover:underline">
                        Voir →
                    </a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

{% endblock %}
