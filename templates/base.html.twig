<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}ClubSport{% endblock %} — ClubSport</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'system-ui', '-apple-system', 'sans-serif'] },
                    colors: {
                        apple: {
                            bg: '#f5f5f7',
                            blue: '#0071e3',
                            'blue-hover': '#0077ed',
                            text: '#1d1d1f',
                            muted: '#6e6e73',
                            border: '#d2d2d7',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }
        .nav-link { transition: background-color 0.15s ease, color 0.15s ease; }
        .nav-link:hover { background-color: #f5f5f7; }
        .nav-link.active { background-color: #e8f0fe; color: #0071e3; }
        .card { transition: box-shadow 0.2s ease; }
        .card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
    </style>
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body class="bg-[#f5f5f7] text-[#1d1d1f] antialiased">

{# ── Sidebar ── #}
<aside class="fixed top-0 left-0 h-full w-60 bg-white border-r border-[#d2d2d7] flex flex-col z-30">

    {# Logo / Club #}
    <div class="px-5 py-5 border-b border-[#d2d2d7]">
        <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-xl bg-[#0071e3] flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <div class="min-w-0">
                <p class="text-sm font-semibold text-[#1d1d1f] truncate">
                    {% if app.user and app.user.club %}{{ app.user.club.name }}{% else %}ClubSport{% endif %}
                </p>
                <p class="text-xs text-[#6e6e73]">Gestion sportive</p>
            </div>
        </div>
    </div>

    {# Navigation #}
    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">

        <p class="px-3 py-1 text-[10px] font-semibold text-[#6e6e73] uppercase tracking-wider">Principal</p>

        <a href="{{ path('app_dashboard') }}"
           class="nav-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-[#1d1d1f] {{ app.request.get('_route') == 'app_dashboard' ? 'active' : '' }}">
            <svg class="w-4.5 h-4.5 flex-shrink-0" style="width:18px;height:18px" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            Tableau de bord
        </a>

        <p class="px-3 pt-3 pb-1 text-[10px] font-semibold text-[#6e6e73] uppercase tracking-wider">Club</p>

        <a href="{{ path('app_user_index') }}"
           class="nav-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-[#1d1d1f] {{ app.request.get('_route') starts with 'app_user' ? 'active' : '' }}">
            <svg style="width:18px;height:18px" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Membres
        </a>

        <a href="{{ path('app_team_index') }}"
           class="nav-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-[#1d1d1f] {{ app.request.get('_route') starts with 'app_team' ? 'active' : '' }}">
            <svg style="width:18px;height:18px" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"/>
            </svg>
            Équipes
        </a>

        <a href="{{ path('app_event_index') }}"
           class="nav-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-[#1d1d1f] {{ app.request.get('_route') starts with 'app_event' ? 'active' : '' }}">
            <svg style="width:18px;height:18px" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            Événements
        </a>

        <p class="px-3 pt-3 pb-1 text-[10px] font-semibold text-[#6e6e73] uppercase tracking-wider">Terrain</p>

        <a href="#"
           class="nav-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-[#6e6e73]">
            <svg style="width:18px;height:18px" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
            </svg>
            <span class="flex-1">Appel</span>
            <span class="text-[10px] bg-[#f5f5f7] text-[#6e6e73] px-1.5 py-0.5 rounded-md font-medium">Bientôt</span>
        </a>

    </nav>

    {# User card at bottom #}
    <div class="px-3 py-3 border-t border-[#d2d2d7]">
        {% if app.user %}
        <div class="flex items-center gap-3 px-2 py-2 rounded-xl hover:bg-[#f5f5f7] group">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#0071e3] to-[#00c7be] flex items-center justify-center text-white text-xs font-semibold flex-shrink-0">
                {{ app.user.firstname|first|upper }}{{ app.user.lastname|first|upper }}
            </div>
            <div class="flex-1 min-w-0">
                <p class="text-xs font-semibold text-[#1d1d1f] truncate">{{ app.user.firstname }} {{ app.user.lastname }}</p>
                <p class="text-[10px] text-[#6e6e73] truncate">{{ app.user.role }}</p>
            </div>
            <a href="{{ path('app_logout') }}" title="Déconnexion" class="opacity-0 group-hover:opacity-100 transition-opacity">
                <svg style="width:16px;height:16px" fill="none" stroke="#6e6e73" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                </svg>
            </a>
        </div>
        {% endif %}
    </div>
</aside>

{# ── Main area ── #}
<div class="ml-60 min-h-screen flex flex-col">

    {# Top bar #}
    <header class="sticky top-0 z-20 bg-white/80 backdrop-blur-md border-b border-[#d2d2d7] px-8 py-3 flex items-center justify-between">
        <div>
            <h1 class="text-base font-semibold text-[#1d1d1f]">{% block page_title %}{% endblock %}</h1>
            {% block breadcrumb %}{% endblock %}
        </div>
        <div class="flex items-center gap-3">
            {% block header_actions %}{% endblock %}
        </div>
    </header>

    {# Flash messages #}
    {% for type, messages in app.flashes %}
        {% for message in messages %}
        <div class="mx-8 mt-4 px-4 py-3 rounded-xl text-sm font-medium
            {% if type == 'success' %}bg-green-50 text-green-700 border border-green-200
            {% elseif type == 'error' or type == 'danger' %}bg-red-50 text-red-700 border border-red-200
            {% elseif type == 'warning' %}bg-amber-50 text-amber-700 border border-amber-200
            {% else %}bg-blue-50 text-blue-700 border border-blue-200{% endif %}">
            {{ message }}
        </div>
        {% endfor %}
    {% endfor %}

    {# Page content #}
    <main class="flex-1 px-8 py-6">
        {% block body %}{% endblock %}
    </main>
</div>

</body>
</html>
