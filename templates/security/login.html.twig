<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion — ClubSport</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>body { font-family: 'Inter', -apple-system, sans-serif; }</style>
    {% block javascripts %}{{ importmap('app') }}{% endblock %}
</head>
<body class="min-h-screen bg-[#f5f5f7] flex items-center justify-center px-4">

<div class="w-full max-w-sm">

    {# Logo #}
    <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-[#0071e3] mb-4 shadow-lg shadow-blue-200">
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M6 3a1 1 0 011-1h.01a1 1 0 010 2H7a1 1 0 01-1-1zm2 3a1 1 0 00-2 0v1a2 2 0 00-2 2v1a2 2 0 00-2 2v.683a3.7 3.7 0 011.055.485 1.704 1.704 0 001.89 0 3.704 3.704 0 014.11 0 1.704 1.704 0 001.89 0 3.704 3.704 0 014.11 0 1.704 1.704 0 001.89 0A3.7 3.7 0 0118 12.683V12a2 2 0 00-2-2V9a2 2 0 00-2-2V6a1 1 0 10-2 0v1h-1V6a1 1 0 10-2 0v1H8V6zm10 8.868a3.704 3.704 0 01-4.055-.036 1.704 1.704 0 00-1.89 0 3.704 3.704 0 01-4.11 0 1.704 1.704 0 00-1.89 0A3.704 3.704 0 012 14.868V17a1 1 0 001 1h14a1 1 0 001-1v-2.132zM9 3a1 1 0 011-1h.01a1 1 0 110 2H10a1 1 0 01-1-1zm3 0a1 1 0 011-1h.01a1 1 0 110 2H13a1 1 0 01-1-1z" clip-rule="evenodd"/>
            </svg>
        </div>
        <h1 class="text-2xl font-semibold text-[#1d1d1f]">ClubSport</h1>
        <p class="mt-1 text-sm text-[#6e6e73]">Connectez-vous à votre espace</p>
    </div>

    {# Card #}
    <div class="bg-white rounded-2xl shadow-sm border border-[#d2d2d7] px-7 py-8">

        {% if error %}
        <div class="mb-5 px-4 py-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700 flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
        {% endif %}

        <form method="post" class="space-y-4">

            <div>
                <label for="inputEmail" class="block text-sm font-medium text-[#1d1d1f] mb-1.5">Adresse e-mail</label>
                <input type="email"
                       id="inputEmail"
                       name="email"
                       value="{{ last_username }}"
                       autocomplete="email"
                       required
                       autofocus
                       class="w-full px-3.5 py-2.5 text-sm bg-[#f5f5f7] border border-[#d2d2d7] rounded-xl focus:outline-none focus:ring-2 focus:ring-[#0071e3] focus:border-transparent transition-all placeholder-[#6e6e73]"
                       placeholder="nom@example.com">
            </div>

            <div>
                <div class="flex items-center justify-between mb-1.5">
                    <label for="inputPassword" class="block text-sm font-medium text-[#1d1d1f]">Mot de passe</label>
                </div>
                <input type="password"
                       id="inputPassword"
                       name="password"
                       autocomplete="current-password"
                       required
                       class="w-full px-3.5 py-2.5 text-sm bg-[#f5f5f7] border border-[#d2d2d7] rounded-xl focus:outline-none focus:ring-2 focus:ring-[#0071e3] focus:border-transparent transition-all placeholder-[#6e6e73]"
                       placeholder="••••••••">
            </div>

            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

            <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="checkbox" name="_remember_me"
                       class="w-4 h-4 rounded border-[#d2d2d7] text-[#0071e3] focus:ring-[#0071e3] accent-[#0071e3]">
                <span class="text-sm text-[#6e6e73]">Se souvenir de moi</span>
            </label>

            <button type="submit"
                    class="w-full py-2.5 px-4 bg-[#0071e3] hover:bg-[#0077ed] text-white text-sm font-medium rounded-xl transition-colors duration-150 shadow-sm">
                Se connecter
            </button>

        </form>
    </div>

    <p class="text-center mt-6 text-xs text-[#6e6e73]">© {{ "now"|date("Y") }} ClubSport. Tous droits réservés.</p>
</div>

</body>
</html>
